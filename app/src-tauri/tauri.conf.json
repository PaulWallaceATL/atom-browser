{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atom Browser",
  "version": "0.1.0",
  "identifier": "com.atombrowser.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Atom Browser",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": []
  },
  "plugins": {
    "opener": {}
  }
}
